# ZeptoCode Baseline Measurement Configuration
# Generated: 2026-04-20T23:20:00Z

# Baseline Version
BASELINE_VERSION=v1
BASELINE_TIMESTAMP=2026-04-20T23:20:00Z

# Primary Model (Ollama-Primary Strategy)
PRIMARY_MODEL=opencode-model:latest
PRIMARY_MODEL_PROVIDER=ollama
PRIMARY_MODEL_DETAILS=gemma4:31b

# Embedding Model (for semantic search and Qdrant)
EMBEDDING_MODEL=nomic-embed-text:latest
EMBEDDING_VECTOR_SIZE=384
EMBEDDING_DISTANCE_METRIC=Cosine

# OpenCode Configuration
OPENCODE_OLLAMA_PORT=8000
OPENCODE_SERVER_PORT=4096

# Qdrant Configuration
QDRANT_HOST=localhost
QDRANT_PORT=6333
QDRANT_API_BASE=http://localhost:6333

# Test Collections (per-profile baseline versioning)
SUBAGENT_TEST_COLLECTION_PREFIX=prompt-engineering-test-harness
E2E_TEST_COLLECTION_PREFIX=e2e-test-harness
BASELINE_COLLECTION_SUFFIX=-baseline-v1

# Braintrust Configuration
BRAINTRUST_API_KEY=${BRAINTRUST_API_KEY:-}
BRAINTRUST_VERSION=3.9.0

# Test Harness Parameters
TEST_SUBAGENT_TRIALS=3
TEST_E2E_GOAL_VARIATIONS=5
TEST_TIMEOUT_MS=60000
TEST_SETUP_TIMEOUT_MS=20000

# Optimization Strategy
OPTIMIZATION_SCOPE=full
OPTIMIZATION_SCOPE_DETAILS=8_agent_prompts_22_dag_node_prompts
MODEL_PRIORITIZATION=ollama-primary
VALIDATION_STRATEGY=ollama_only_iteration_then_tier3_validation
CONVERGENCE_THRESHOLD_PERCENT=2
CONVERGENCE_ITERATIONS=3

# Hard Constraints (All must maintain 100%)
HARD_CONSTRAINT_CODE_VALIDATION=100%
HARD_CONSTRAINT_VERIFICATION_ACCURACY=100%
HARD_CONSTRAINT_CITATION_TRACEABILITY=100%
HARD_CONSTRAINT_SOURCE_CONFIDENCE_TAGGING=100%
HARD_CONSTRAINT_FACTUAL_ACCURACY=100%
HARD_CONSTRAINT_CONVENTION_ADHERENCE=100%
HARD_CONSTRAINT_CONTRADICTION_PRESERVATION=100%

# Soft Objectives
BASELINE_THRESHOLD_HARD_CONSTRAINTS=90%
BASELINE_THRESHOLD_SOFT_OBJECTIVES=85%

# Profiles to Validate (Tier 3)
PROFILES_TIER3=naga,naga-haiku,naga-copilot,naga-haiku-copilot,naga-free

# Logging
LOG_SETUP_FILE=.setup-log.txt
LOG_LEVEL=info
